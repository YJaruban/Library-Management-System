<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<VBox spacing="15" alignment="CENTER"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.library.SearchController"
      style="-fx-padding: 20;">

    <Label text="Book Availability Search"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TextField fx:id="searchField" promptText="Enter title or Py*" prefWidth="250"/>
    <Button text="Search" onAction="#onSearch"/>

    <ListView fx:id="listView" prefWidth="500" prefHeight="220"/>

    <Button text="Export to Text File" onAction="#onExport"/>
</VBox>